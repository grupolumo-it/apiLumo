# Lumo API Gateway — Variables de entorno (PLANTILLA)
# ------------------------------------------------------------
# Copia este archivo como `.env` y rellena los valores reales:
#   cp .env.example .env
#
# El archivo `.env` está incluido en `.gitignore` y NUNCA debe
# committearse. Solo `.env.example` es seguro de versionar.
# ------------------------------------------------------------

# URL del proyecto Supabase. Formato:
#   https://<project-ref>.supabase.co
SUPABASE_URL=

# Clave "publishable" / anon de Supabase (NO la service_role).
# En Supabase Dashboard -> Settings -> API Keys -> "Publishable key".
SUPABASE_ANON_KEY=

# Dominio ficticio que el Service Worker intercepta.
# Por defecto: api.lumocolombia.com.co (público, no es un secreto).
FICTIONAL_DOMAIN=api.lumocolombia.com.co

# Path de GraphQL dentro de Supabase. Por defecto: /graphql/v1
GRAPHQL_PATH=/graphql/v1

# Origen permitido por CORS en TODAS las respuestas del gateway.
# Por defecto: '*' (útil para dev local; cualquier origen puede leer
# la respuesta).
# En producción ACOTAR a un origen concreto, p.ej.:
#   GATEWAY_CORS_ORIGIN=https://app.lumocolombia.com.co
GATEWAY_CORS_ORIGIN=*